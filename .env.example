# ── Archievers Backend — Environment Variables ──────────────────
# Copy this file to .env and fill in your values

# Server
PORT=3000

# Security — CHANGE THIS to a long random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# CORS — set to your frontend domain in production (e.g. https://archievers.com)
# Leave as * during local development
FRONTEND_URL=*
